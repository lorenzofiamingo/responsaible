# Local secrets for `npm run dev` — copy to `.dev.vars` (gitignored) and fill in.
#
# NONE of these are required. The console runs fully on localhost without them:
# the EU Law (CELLAR) researcher verifies citations against the public EUR-Lex API,
# the Firm-Knowledge researcher retrieves from local D1, and the critic falls back to
# a deterministic, CELLAR-grounded verdict. Add a key only to turn the matching live
# model on — each is consulted only when its key is present.

# Auth (only needed if you want stable sessions across restarts).
# BETTER_AUTH_SECRET=""
# BETTER_AUTH_URL="http://localhost:5173"

# EU Law researcher + critic (Claude). Absent ⇒ deterministic CELLAR-grounded verdict.
# ANTHROPIC_API_KEY=""

# Google models (alternative critic / intake). Absent ⇒ skipped.
# GOOGLE_API_KEY=""
# GEMINI_API_KEY=""

# Web researcher (Perplexity open-web search). Absent ⇒ web step reported unavailable.
# PERPLEXITY_API_KEY=""
# PERPLEXITY_MODEL="sonar"

# Firm-Knowledge researcher's open, self-hostable model (NVIDIA NIM / Nemotron).
# Absent ⇒ firm docs are still retrieved, just not summarised by the model.
# NVIDIA_NIM_API_KEY=""
# NVIDIA_NIM_BASE_URL="https://integrate.api.nvidia.com/v1"
# ITAILY_NEMOTRON_MODEL="nvidia/llama-3.3-nemotron-super-49b-v1"

# CELLAR MCP endpoint the EU Law researcher drives. Absent ⇒ same-origin /api/mcp/cellar.
# CELLAR_MCP_URL=""

# Enable the bounded critic escalation loop (truthy ⇒ on). Absent ⇒ off.
# ITAILY_ESCALATION=""
