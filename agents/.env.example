# Copy this file to `.env` (in the agents/ directory) and fill in your keys.
# `run_seed.py` loads it automatically via python-dotenv.

# --- model selection --------------------------------------------------------------
# Which LLM the ADK agents use. "gemini" (default, native) or "claude" (LiteLlm).
ITAILY_MODEL_PROVIDER=gemini

# Optional model-id overrides (defaults live in itaily_agents/models.py).
# ITAILY_GEMINI_MODEL=gemini-2.5-flash
# ITAILY_CLAUDE_MODEL=anthropic/claude-opus-4-8

# --- Gemini credentials (needed when ITAILY_MODEL_PROVIDER=gemini) -----------------
# Option A: Google AI Studio API key (simplest for local/offline use).
GOOGLE_API_KEY=your-google-ai-studio-key

# Option B: Vertex AI instead of AI Studio. If you use Vertex, set these and make
# sure GOOGLE_API_KEY is unset. (Requires `gcloud auth application-default login`.)
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Claude credentials (needed when ITAILY_MODEL_PROVIDER=claude) -----------------
ANTHROPIC_API_KEY=your-anthropic-key

# --- Open model: NVIDIA Nemotron via NIM (firm-knowledge agent / provider=nvidia) --
# Open weights, self-hostable. The knowledge agent ALWAYS uses this so confidential
# firm material never leaves the perimeter. Point NVIDIA_NIM_BASE_URL at a private
# NIM deployment for true on-prem privacy.
NVIDIA_NIM_API_KEY=your-nvidia-nim-key
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
ITAILY_NEMOTRON_MODEL=nvidia_nim/nvidia/llama-3.3-nemotron-super-49b-v1

# --- Web research: Perplexity (web_research agent) ---------------------------------
PERPLEXITY_API_KEY=your-perplexity-key
# PERPLEXITY_MODEL=sonar

# --- Optional research agents / CELLAR-as-MCP -------------------------------------
# Insert the optional research agents into the seed pipeline (each needs its key):
# ITAILY_ENABLE_WEB=1
# ITAILY_ENABLE_KNOWLEDGE=1
# Drive CELLAR via the standalone MCP server instead of in-process tools. Recommended
# for the EU Law Researcher — it mirrors how the runtime console drives CELLAR over MCP
# (src/routes/api/mcp/cellar + src/lib/server/mcp/cellarClient.ts).
# ITAILY_CELLAR_MCP=1

# --- Per-claim ADK WORK GROUP (System B) ------------------------------------------
# Rate each atomic claim with the per-claim ADK graph (claim_workgroup.py): grounding →
# parallel researchers → critic with a bounded escalation loop. This DROPS the batch
# claim_analyzer from the matter pipeline and runs the figures the claim's auto-preset
# selects (mirrors src/lib/server/analyze.ts offline). Needs the API keys for whichever
# models the chosen presets use (e.g. Claude + Perplexity + Nemotron for the full panel).
# ITAILY_CLAIM_WORKGROUP=1
# Max claims analysed concurrently (bounds the model-call burst per matter). Default 2.
# ITAILY_CLAIM_CONCURRENCY=2

# --- Runtime note (the SvelteKit console, not this offline pipeline) ---------------
# The live per-claim work group reaches CELLAR over MCP at its OWN /api/mcp/cellar
# endpoint by default. Set CELLAR_MCP_URL in the Worker env only to point the EU Law
# Researcher at a different CELLAR MCP server. The bounded critic escalation loop is
# off by default; enable it in the Worker env with ITAILY_ESCALATION=1.
